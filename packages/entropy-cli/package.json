{
  "name": "@entropy-engine/entropy-cli",
  "version": "1.7.0",
  "description": "CLI for Entropy Game Engine",
  "author": "Robert Herber <rwherber@gmail.com>",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rob893/Entropy-Game-Engine.git"
  },
  "keywords": [
    "game",
    "engine",
    "typescript",
    "cli"
  ],
  "bugs": {
    "url": "https://github.com/rob893/Entropy-Game-Engine/issues"
  },
  "homepage": "https://github.com/rob893/Entropy-Game-Engine#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run clean-dist && npm run compile",
    "clean-dist": "node -e \"require('fs').rmSync('./dist',{recursive:true,force:true}); require('fs').rmSync('./tsconfig.tsbuildinfo',{force:true});\"",
    "compile": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "@entropy-engine/entropy-cli": "bin/entropy",
    "entropy": "bin/entropy"
  },
  "dependencies": {
    "arg": "^5.0.2",
    "chalk": "^5.6.2",
    "execa": "^9.6.1",
    "inquirer": "^13.3.0",
    "listr2": "^10.2.1",
    "pkg-install": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
