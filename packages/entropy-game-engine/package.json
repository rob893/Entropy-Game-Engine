{
  "name": "@entropy-engine/entropy-game-engine",
  "version": "2.2.0",
  "description": "Custom 2D game engine written in TypeScript.",
  "author": "Robert Herber <rwherber@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rob893/Entropy-Game-Engine.git"
  },
  "keywords": [
    "game",
    "engine",
    "typescript"
  ],
  "bugs": {
    "url": "https://github.com/rob893/Entropy-Game-Engine/issues"
  },
  "homepage": "https://github.com/rob893/Entropy-Game-Engine#readme",
  "main": "dist/index",
  "types": "dist/index",
  "scripts": {
    "build": "npm run clean-dist && npm run compile",
    "clean-dist": "node -e \"require('fs').rmSync('./dist',{recursive:true,force:true}); require('fs').rmSync('./tsconfig.tsbuildinfo',{force:true});\"",
    "compile": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  }
}
