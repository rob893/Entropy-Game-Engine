{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  // For launch against localhost, be sure to have the Vite dev server running (npm start) and the port numbers the same.
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch CLI",
      "program": "${workspaceFolder}/packages/entropy-cli/bin/entropy",
      "console": "integratedTerminal",
      "args": ["init"],
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach by Process ID",
      "processId": "${command:PickProcess}",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome - Game 1",
      "url": "http://localhost:8080/entropy/sample-game-1/",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "http://localhost:8080/entropy/sample-game-1/src/*": "${workspaceFolder}/sample-games/sample-game-1/src/*",
        "/entropy/sample-game-1/src/*": "${workspaceFolder}/sample-games/sample-game-1/src/*",

        "http://localhost:8080/entropy/sample-game-1/@fs/*": "/*",
        "http://localhost:8080/@fs/*": "/*",
        "/@fs/*": "/*"
      }
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome - Game 2",
      "url": "http://localhost:8080/entropy/sample-game-2/",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "http://localhost:8080/entropy/sample-game-2/src/*": "${workspaceFolder}/sample-games/sample-game-2/src/*",
        "/entropy/sample-game-2/src/*": "${workspaceFolder}/sample-games/sample-game-2/src/*",

        "http://localhost:8080/entropy/sample-game-2/@fs/*": "/*",
        "http://localhost:8080/@fs/*": "/*",
        "/@fs/*": "/*"
      }
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome - Game 3",
      "url": "http://localhost:8080/entropy/sample-game-3/",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "http://localhost:8080/entropy/sample-game-3/src/*": "${workspaceFolder}/sample-games/sample-game-3/src/*",
        "/entropy/sample-game-3/src/*": "${workspaceFolder}/sample-games/sample-game-3/src/*",

        "http://localhost:8080/entropy/sample-game-3/@fs/*": "/*",
        "http://localhost:8080/@fs/*": "/*",
        "/@fs/*": "/*"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Vitest All",
      "program": "${workspaceFolder}/node_modules/.bin/vitest",
      "args": ["run"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Vitest Current File",
      "program": "${workspaceFolder}/node_modules/.bin/vitest",
      "args": ["run", "${relativeFile}"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
