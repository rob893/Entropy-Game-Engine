{
  "name": "entropy-game-engine",
  "version": "1.0.0",
  "description": "Custom 2D game engine written in TypeScript.",
  "private": true,
  "workspaces": [
    "packages/*",
    "sample-games/*"
  ],
  "scripts": {
    "compile": "tsc --build tsconfig.build.json",
    "compile-clean": "tsc --build tsconfig.build.json --clean",
    "watch": "tsc --build tsconfig.build.json --watch",
    "build-games": "npm run build-game --workspaces --if-present",
    "clean-dist": "npm run clean-dist --workspaces --if-present",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "prettier": "prettier --write **/*.{ts,js,css,html,json} !**/node_modules/** !**/dist/** !**/coverage/** !**/compiled/**",
    "format": "npm run prettier",
    "test": "vitest run --coverage",
    "test-watch": "vitest --coverage",
    "start": "npm run start -w @entropy-engine/sample-game-1",
    "start:game1": "npm run start -w @entropy-engine/sample-game-1",
    "start:game2": "npm run start -w @entropy-engine/sample-game-2",
    "start:game3": "npm run start -w @entropy-engine/sample-game-3",
    "check:editor": "tsc --noEmit -p ./packages/entropy-editor/tsconfig.json",
    "dev:editor": "npm run dev -w @entropy-engine/entropy-editor",
    "build:editor": "npm run build -w @entropy-engine/entropy-editor",
    "outdated:all": "npm outdated --workspaces --include-workspace-root",
    "ls:all": "npm ls --workspaces --include-workspace-root --depth=0",
    "publish:packages": "npm publish --workspaces --access public --no-git-checks",
    "workspace:outdated": "npm outdated --workspaces --include-workspace-root"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rob893/Entropy-Game-Engine.git"
  },
  "keywords": [
    "game",
    "engine",
    "typescript"
  ],
  "author": "Robert Herber",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rob893/Entropy-Game-Engine/issues"
  },
  "homepage": "https://github.com/rob893/Entropy-Game-Engine#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.12",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jest-matcher-deep-close-to": "^3.0.2",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0",
    "vitest-canvas-mock": "^1.1.3"
  },
  "lint-staged": {
    "*.{ts,js}": "eslint --fix",
    "*.{ts,js,css,html,json}": "prettier --write"
  }
}
