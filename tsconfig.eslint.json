{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "paths": {
      "*": ["@types/*"],
      "@entropy-engine/entropy-game-engine": ["packages/entropy-game-engine/src"],
      "@entropy-engine/entropy-game-engine/*": ["packages/entropy-game-engine/src/*"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "sample-games/**/*.ts",
    "@types/**/*.d.ts",
    "*.config.*",
    "vitest.config.ts"
  ],
  "exclude": ["**/node_modules", "**/dist", "**/templates"]
}
